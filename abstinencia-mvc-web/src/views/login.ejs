<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Abstenin | Ingreso</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <main class="page">
    <section class="card auth-card">
      <h1>Abstenin</h1>
      <p>Ingreso a tu cuenta</p>
      <% if (error) { %><p class="error"><%= error %></p><% } %>
      <form method="post" action="/login" class="form-grid">
        <label for="email">Correo</label>
        <input id="email" type="email" name="email" placeholder="tu@correo.com" required />

        <label for="password">Contrasena</label>
        <input id="password" type="password" name="password" placeholder="Tu contrasena" required />

        <button type="submit">Entrar</button>
      </form>
      <p><a href="/register">Crear cuenta</a></p>
    </section>
  </main>
</body>
</html>
